{
  "manifest_version": 3,
  "name": "Flux Planner",
  "version": "1.2.0",
  "description": "Flux AI — automatically understands every page you visit",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel",
    "tabs",
    "windows",
    "contextMenus",
    "identity",
    "notifications",
    "webNavigation"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Flux Planner",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["sidebar.html", "sidebar.js", "sidebar.css", "auth-google.js", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "externally_connectable": {
    "matches": [
      "https://azfermohammed.github.io/*",
      "https://fluxplanner.github.io/*",
      "https://*.github.io/*",
      "http://localhost:*/*",
      "http://127.0.0.1:*/*",
      "https://localhost:*/*",
      "https://127.0.0.1:*/*"
    ]
  }
}
